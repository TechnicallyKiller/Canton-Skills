---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import SkillCard from '../../components/SkillCard.astro';
import { TRACKS, SKILL_COUNT } from '../../data/skills';
---
<Base
  title="Skills — Canton Dev Skills"
  description={`Browse all ${SKILL_COUNT} Canton / Daml / Zenith agent skills, with their verification status.`}
>
  <Nav />
  <main class="container-x py-16 sm:py-20">
    <p class="eyebrow">// the catalog</p>
    <h1 class="mt-3 font-display text-4xl font-bold tracking-tight">{SKILL_COUNT} skills</h1>
    <p class="mt-3 max-w-2xl text-muted">
      Each is narrow, well-triggered, and source-traced to canonical Canton / Zenith docs.
      Badges show exactly how far each is verified — no overclaiming.
    </p>
    <div class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-2 font-mono text-xs text-muted">
      <span><span class="text-ok">✅</span> verified</span>
      <span><span class="text-warn">🔎</span> source-verified</span>
      <span><span class="text-preview">🧪</span> preview (pre-MainNet)</span>
    </div>

    <div class="mt-12 space-y-10">
      {TRACKS.map((track) => (
        <div>
          <div class="mb-4 flex items-center gap-3">
            <h2 class="font-display text-sm font-semibold uppercase tracking-wider text-accent-2">{track.title}</h2>
            <div class="h-px flex-1 bg-border"></div>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {track.skills.map((skill) => <SkillCard skill={skill} />)}
          </div>
        </div>
      ))}
    </div>
  </main>
  <Footer />
</Base>
