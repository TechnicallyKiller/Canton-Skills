---
import { BADGES, type Skill } from '../data/skills';
interface Props { skill: Skill }
const { skill } = Astro.props;
const badge = BADGES[skill.badge];
---
<a href={`/skills/${skill.name}`} class="card group flex flex-col p-5">
  <div class="flex items-start justify-between gap-3">
    <h3 class="font-mono text-sm font-medium text-text group-hover:text-accent">{skill.name}</h3>
    <span class={`badge ${badge.cls}`} title={badge.tip}>{badge.label}</span>
  </div>
  <p class="mt-2.5 text-sm leading-relaxed text-muted">{skill.blurb}</p>
  <span class="mt-3 font-mono text-xs text-muted/70 transition group-hover:text-accent">view skill →</span>
</a>
