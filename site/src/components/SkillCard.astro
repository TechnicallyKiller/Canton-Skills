---
import { BADGES, REPO, type Skill } from '../data/skills';
interface Props { skill: Skill }
const { skill } = Astro.props;
const badge = BADGES[skill.badge];
const href = `https://github.com/${REPO}/blob/main/skills/${skill.name}/SKILL.md`;
---
<a href={href} target="_blank" rel="noopener" class="card group flex flex-col p-5">
  <div class="flex items-start justify-between gap-3">
    <h3 class="font-mono text-sm font-medium text-text group-hover:text-accent">{skill.name}</h3>
    <span class={`shrink-0 rounded-md border px-1.5 py-0.5 text-[10px] font-medium ${badge.cls}`} title={badge.tip}>
      {badge.label}
    </span>
  </div>
  <p class="mt-2.5 text-sm leading-relaxed text-muted">{skill.blurb}</p>
  <span class="mt-3 text-xs text-muted/70 transition group-hover:text-accent">View skill →</span>
</a>
