---
import { TRACKS, SKILL_COUNT } from '../data/skills';
import SkillCard from './SkillCard.astro';
---
<section id="skills" class="container-x py-20 sm:py-28">
  <div class="reveal mx-auto max-w-2xl text-center">
    <p class="eyebrow">// the catalog</p>
    <h2 class="mt-4 font-display text-3xl font-bold tracking-tight sm:text-4xl">
      {SKILL_COUNT} focused skills, not one monolith
    </h2>
    <p class="mt-4 text-muted">
      Each is narrow, well-triggered, and source-traced to canonical Canton / Zenith docs. Badges show
      exactly how far each is verified — no overclaiming.
    </p>
    <div class="mt-5 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-xs text-muted">
      <span><span class="text-ok">✅</span> verified</span>
      <span><span class="text-warn">🔎</span> source-verified</span>
      <span><span class="text-preview">🧪</span> preview (pre-MainNet)</span>
    </div>
  </div>

  <div class="mt-12 space-y-10">
    {TRACKS.map((track) => (
      <div class="reveal">
        <div class="mb-4 flex items-center gap-3">
          <h3 class="font-display text-sm font-semibold uppercase tracking-wider text-accent-2">{track.title}</h3>
          <div class="h-px flex-1 bg-border"></div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {track.skills.map((skill) => <SkillCard skill={skill} />)}
        </div>
      </div>
    ))}
  </div>
</section>
